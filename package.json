{
  "name": "termui",
  "version": "0.0.5",
  "private": true,
  "description": "A TypeScript-first framework for building beautiful, interactive terminal user interfaces",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "bun vitest run",
    "test:watch": "bun vitest",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "bench": "bun packages/core/src/benchmark/render-loop.ts",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.2.3",
    "tsup": "^8.3.0",
    "turbo": "^2.9.12",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=18.0.0"
  },
  "homepage": "https://www.termui.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/Karanjot786/TermUI"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^15.0.0"
  }
}
