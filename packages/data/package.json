{
  "name": "@termuijs/data",
  "homepage": "https://www.termui.io/docs/guides/quick",
  "repository": {
    "type": "git",
    "url": "https://github.com/Karanjot786/TermUI"
  },
  "version": "0.1.7",
  "description": "System data providers for TermUI: CPU, memory, disk, processes, network",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@termuijs/jsx": "workspace:*"
  },
  "devDependencies": {
    "@termuijs/testing": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsup": "^8.3.0"
  },
  "keywords": [
    "terminal",
    "tui",
    "cli",
    "data",
    "system-monitor",
    "cpu",
    "memory"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=18.0.0"
  }
}
